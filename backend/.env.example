DATABASE_URL=sqlite:///./khetsmart.db
DEMO_MODE=false
# Copernicus Data Space OAuth (https://dataspace.copernicus.eu/ → OAuth clients)
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=
# Legacy: single secret only works if CLIENT_ID is also set
# COPERNICUS_API_KEY=
DATA_GOV_API_KEY=
# Mandi resource (default: Agmarknet daily prices catalog)
# DATAGOV_MANDI_RESOURCE_ID=9ef84268-d588-465a-a308-a864a43d0070
# SKIP_DATAGOV_MANDI=true
# DATAGOV_MANDI_MAX_PAGES=30
# DATAGOV_MANDI_MIN_MARKETS=6
# Cold storage registry (MoFPI / OGD state-UT distribution)
# DATAGOV_REGISTRY_RESOURCE_ID=f74278bb-fe8a-41b1-af9b-a38690edf197
# Production: lock Ops tab + /api/admin/*
ADMIN_API_KEY=
REQUIRE_ADMIN_AUTH=true
# Routing distances (public OSRM demo; set USE_OSRM=false if slow)
USE_OSRM=true
OSRM_BASE_URL=https://router.project-osrm.org
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# OpenWeatherMap — live weather on Predict tab (https://openweathermap.org/api)
OPENWEATHER_API_KEY=

# Google Gemini — AI crop brain (https://aistudio.google.com/)
GEMINI_API_KEY=

# Razorpay — enable UPI & card on checkout (Test keys from dashboard)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=

# Farmer OTP (dev: prints OTP in API response + server console)
OTP_DEV_EXPOSE=true
OTP_LENGTH=6
OTP_TTL_MINUTES=10
